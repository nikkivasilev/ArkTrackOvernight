# Copy to backend/.env and edit. See README.md "Configuration".

# Database — Postgres on host port 5433 (container port 5432; see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/bestfactor

# Detection confidence floor for the local D-FINE-L detector.
DFINE_DEFAULT_CONF=0.4

# Remote D-FINE-L HTTP service — UNUSED while detection runs locally on GPU
# (yolo_source_active="dfine-l"). Kept as a fallback source.
DFINE_URL=http://10.0.0.5:8015/predict/image
DFINE_API_KEY=replace-me

# Qwen3-next VLM (vision-capable) for activity classification. Must be reachable.
QWEN_BASE_URL=http://192.168.0.33:8000/v1
QWEN_MODEL=/models/qwen3-next

# CORS / dev
CORS_ORIGINS=["http://localhost:5173"]

# Pipeline
INFERENCE_SEMAPHORE_SIZE=4
DEFAULT_SAMPLING_FPS=8.0
